{
    "include": ["src", "package"],
    "compilerOptions": {
        "module": "preserve",
        "target": "es2024",
        "moduleResolution": "bundler",
        "strict": true,
        "noLib": true,
        "types": ["@bedrock-apis/env-types"],
        "noEmit": true,
        "paths": {
            "*": ["./src/*"],
            "ScriptBoxMC": ["./package/main.ts"]
        }
    }
}
